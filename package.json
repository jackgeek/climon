{
  "name": "climon",
  "version": "3.2.1",
  "description": "Web-based monitor for interactive CLI terminals with a built-in PTY session manager and web terminal.",
  "license": "MIT",
  "author": "Brodie Jack Allan",
  "repository": {
    "type": "git",
    "url": "https://github.com/jackgeek/climon.git"
  },
  "type": "module",
  "bin": {
    "climon-server": "./src/server.ts"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:server": "bun build ./src/server.ts --outdir ./dist --target bun --format esm",
    "build:web": "bun scripts/build-web.ts",
    "build:rust": "bun scripts/build-rust.ts",
    "build": "bun run clean && bun run build:web && bun run build:server && bun run build:rust",
    "postinstall": "bun scripts/rust-toolchain.ts",
    "compile": "bun scripts/compile.ts",
    "sign-release": "bun scripts/sign-release.ts",
    "verify-signing-key": "bun scripts/verify-signing-key.ts",
    "check:peers": "bun scripts/check-peer-deps.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "bun run typecheck && bun run messages:check",
    "test": "bun test tests",
    "release": "bun scripts/release.ts",
    "dev": "bun scripts/dev.ts",
    "server": "bun src/server.ts server",
    "server:loop": "bun scripts/server-loop.ts",
    "logs": "bun scripts/logs.ts",
    "stats:downloads": "bash scripts/download-stats.sh",
    "log-level": "bun scripts/log-level.ts",
    "docs:config": "bun scripts/generate-config-docs.ts",
    "messages:extract": "bun scripts/extract-messages.ts extract",
    "messages:check": "bun scripts/extract-messages.ts check",
    "messages:merge": "bun scripts/extract-messages.ts merge",
    "messages:hints": "bun scripts/extract-messages.ts hints",
    "messages:publish": "bun scripts/extract-messages.ts publish"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@fluentui/react-components": "^9.74.3",
    "@fluentui/react-icons": "^2.0.332",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "applicationinsights": "^3.15.1",
    "human-id": "^4.2.0",
    "pino": "^10.3.1",
    "pino-applicationinsights": "^2.1.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "web-push": "^3.6.7",
    "xterm-theme": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "bun-types": "^1.3.10",
    "fflate": "^0.8.3",
    "typescript": "^7.0.2"
  }
}
