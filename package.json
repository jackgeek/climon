{
  "name": "climon",
  "version": "0.12.0",
  "description": "Web-based monitor for interactive CLI terminals with a built-in PTY session manager and web terminal.",
  "type": "module",
  "bin": {
    "climon": "./src/index.ts",
    "climon-server": "./src/server.ts"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build ./src/index.ts --outdir ./dist --target bun --format esm",
    "build:server": "bun build ./src/server.ts --outdir ./dist --target bun --format esm",
    "build:web": "bun scripts/build-web.ts",
    "build:all": "bun run build && bun run build:web && bun run build:server",
    "compile": "bun scripts/compile.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "bun run typecheck",
    "test": "bun test tests",
    "release": "bun scripts/release.ts",
    "dev": "bun src/index.ts",
    "server": "bun src/server.ts server",
    "start": "bun src/index.ts",
    "docs:config": "bun scripts/generate-config-docs.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-icons": "^2.0.328",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^5.5.0",
    "applicationinsights": "^3.15.0",
    "human-id": "^4.2.0",
    "pino": "^10.3.1",
    "pino-applicationinsights": "^2.1.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "bun-types": "^1.3.10",
    "fflate": "^0.8.3",
    "typescript": "^5.5.4"
  }
}
